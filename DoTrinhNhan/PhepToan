import java.util.Scanner;

public class PhepToanCoBan {
    public static void main(String[] args) {
        // Khởi tạo đối tượng Scanner để nhập dữ liệu
        Scanner sc = new Scanner(System.in);

        System.out.print("Nhập số thứ nhất (a): ");
        double a = sc.nextDouble();

        System.out.print("Nhập số thứ hai (b): ");
        double b = sc.nextDouble();

        // Thực hiện các phép tính
        double tong = a + b;
        double hieu = a - b;
        double tich = a * b;

        // Hiển thị kết quả
        System.out.println("\n--- Kết quả ---");
        System.out.println("Tổng: " + a + " + " + b + " = " + tong);
        System.out.println("Hiệu: " + a + " - " + b + " = " + hieu);
        System.out.println("Tích: " + a + " * " + b + " = " + tich);

        // Kiểm tra điều kiện chia cho 0
        if (b != 0) {
            double thuong = a / b;
            System.out.println("Thương: " + a + " / " + b + " = " + thuong);
        } else {
            System.out.println("Không thể thực hiện phép chia vì số thứ hai bằng 0.");
        }

        sc.close(); // Đóng scanner sau khi dùng xong
    }
}